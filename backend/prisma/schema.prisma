generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EquipmentStatus {
  DISPONIVEL
  MANUTENCAO
  INATIVO
  AGUARDANDO_REVISAO
}

model Room {
  id Int @id @default(autoincrement())

  name     String
  building String
  floor    Int
  campus   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipments Equipment[]
}

model Equipment {
  id Int @id @default(autoincrement())

  name                String
  serialNumber        String?
  photo               String?
  responsibleEmployee String?
  observations        String?
  instructions        String?
  attachedDocuments   String[]

  subdivisions Int?
  status       EquipmentStatus @default(DISPONIVEL)

  roomId Int
  room   Room @relation(fields: [roomId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations ReservationEquipment[]

  maintenances Maintenance[]
}

model Reservation {
  id Int @id @default(autoincrement())

  user                String
  startDate           DateTime
  endDate             DateTime
  returnedAt          DateTime?
  observations        String?
  hadIssue            Boolean @default(false)
  returnObservations  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipments ReservationEquipment[]
}

model ReservationEquipment {
  id Int @id @default(autoincrement())

  reservationId Int
  equipmentId   Int

  subdivisionsQuantity Int?

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  equipment   Equipment   @relation(fields: [equipmentId], references: [id])

  @@unique([reservationId, equipmentId])
}

model Maintenance {
  id Int @id @default(autoincrement())

  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  startDate         DateTime  @default(now())
  endDate           DateTime?
  responsiblePerson String?
  observations      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
